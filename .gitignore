# Model cache (ignore generated cache, NOT trained models)
backend/cache/
# Note: core runtime models are tracked so the app + thesis are reproducible:
#   lifespan: xgboost_model, rf_model, lightgbm_model, feature_columns,
#             categorical_features, numeric_features, training_metrics.json,
#             model_manifest.json  AND the dataset they were trained on.
# The pinned image-classifier snapshot is committed through Git LFS under
# backend/models/classifier so clones can build the offline Windows release.
# Legacy classifier weights (zero-shot replaced the old ResNet model)
backend/models/latest/
# Bootstrap/synthetic IMAGE dataset is large + regenerable via
# scripts/fetch_image_dataset.py — keep it out of git. Replace with real
# institutional photos locally for thesis-grade accuracy.
backend/data/images/

