# Browser-safe Clerk development publishable key returned by /api/runtime-config.
# Localhost must use pk_test_; never put a Clerk secret key or pk_live_ value here.
EWASTE_CLERK_PUBLISHABLE_KEY=pk_test_replace-with-your-development-key

# Clerk JWKS endpoint used to verify session JWTs (required for protected APIs).
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json

# Optional JWT claim checks. Uncomment only with the exact values issued by Clerk.
# CLERK_ISSUER=https://your-clerk-instance.clerk.accounts.dev
# CLERK_AUDIENCE=your-clerk-audience

# Optional extra guard for non-browser API clients that explicitly send
# X-Delete-Key. Leave this UNSET for the packaged React UI: secrets must not be
# exposed to browser JavaScript, so that UI intentionally sends no delete key.
# DELETE_API_KEY=replace-with-a-random-secret

# Comma-separated browser origins allowed by CORS.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Runtime path overrides. The packaged Windows defaults are under
# %LOCALAPPDATA%\EWasteManagement; normally do not override them.
# EWASTE_DATA_DIR=C:\Users\you\AppData\Local\EWasteManagement
# EWASTE_CONFIG_PATH=C:\path\to\.env
# EWASTE_DB_PATH=C:\path\to\scan_history.db
# EWASTE_LOG_DIR=C:\path\to\logs
# EWASTE_BACKUP_DIR=C:\path\to\backups
# EWASTE_FRONTEND_DIR=C:\path\to\frontend
# EWASTE_LIFESPAN_MODEL_DIR=C:\path\to\models\lifespan
# EWASTE_CLASSIFIER_MODEL_PATH=C:\path\to\models\classifier\siglip2-base

# Require the SPA build during readiness. The frozen release enables this.
# EWASTE_REQUIRE_FRONTEND=1

# Pre-trained zero-shot classifier preset. The default is the lower-memory model.
# Other primary presets: siglip2-so400m-256, siglip2-so400m-384,
# siglip2-so400m-512, siglip2-large-512, siglip2-giant-384, clip-base.
EWASTE_MODEL=siglip2-base

# Optional finite [0,1] overrides for the selected model family's heuristic
# rejection thresholds. Leave unset to use the code-level family defaults.
# These are tuning controls, not calibrated probabilities or accuracy claims.
# CLASSIFY_THRESHOLD=0.02
# ELECTRONIC_THRESHOLD=0.015
# MARGIN_THRESHOLD=0.004

# Per-user scan requests allowed in each 60-second in-process window.
SCAN_RATE_LIMIT=30

# Maximum result-cache accounting limit in MiB.
CACHE_MAX_MEMORY_MB=256

# DEBUG, INFO, WARNING, ERROR, or CRITICAL.
LOG_LEVEL=INFO

# Keep model artifacts preloaded in normal operation. Set to 1 only for tests or
# diagnostics that intentionally skip classifier warmup and lifespan ML loads.
EWASTE_SKIP_MODEL_PRELOAD=0

# Native numerical libraries default to one thread in app/main.py. These values
# are loaded before app import when run_backend.sh passes this file to Uvicorn.
OMP_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
MKL_NUM_THREADS=1

# Source development is online by default. The Windows release bundles the
# pinned snapshot, sets this to 1, and refuses any Hugging Face fallback.
# HF_HUB_OFFLINE=1
