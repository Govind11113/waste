# Source-development fallback only. Replace this placeholder with a real Clerk
# DEVELOPMENT publishable key (pk_test_). Production builds fetch the key from
# the backend's same-origin /api/runtime-config and do not embed this value.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace-with-your-development-key

# Vite development proxy target only; browser application code keeps relative
# /api URLs. The packaged build serves SPA and API together on 127.0.0.1.
VITE_API_URL=http://127.0.0.1:8000
